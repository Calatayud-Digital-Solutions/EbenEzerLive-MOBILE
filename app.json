{
  "expo": {
    "name": "EbenEzerLiveExpo",
    "slug": "EbenEzerLiveExpo",
    "scheme": "eben-ezer-live",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.tuempresa.eben-ezer-live"
    },
    "android": {
      "package": "com.tuempresa.eben_ezer_live",
      "permissions": [
        "INTERNET",
        "WAKE_LOCK",
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.tuempresa.eben_ezer_live"
    },
    "owner": "calaespi",
    "extra": {
      "eas": {
        "projectId": "f5c0f329-f9f3-4c74-ac01-7a9ce59e1094"
      }
    }
  }
}
