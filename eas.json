{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "distribution": "store",
        "image": "sdk-54",
        "autoIncrement": true
      },
      "ios": {
        "distribution": "store",
        "autoIncrement": true
      },
      "distribution": "store"
    },
    "release": {
      "extends": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6759227856"
      }
    }
  }
}
